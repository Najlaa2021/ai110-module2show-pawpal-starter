classDiagram
    class Owner {
        +name: str
        +availability_minutes: int
        +preferred_time_window: str
        +pets: List[Pet]
        +add_pet(pet)
        +remove_pet(name)
        +create_daily_plan(date)
    }

    class Pet {
        +name: str
        +species: str
        +age: int
        +preferences: List[str]
        +tasks: List[Task]
        +add_task(task)
        +remove_task(title)
        +update_preferences(preferences)
    }

    class Task {
        +title: str
        +duration_minutes: int
        +priority: str
        +category: str
        +scheduled_time: datetime
        +completed: bool
        +pet: Pet
        +mark_complete()
        +reschedule(time)
        +update_priority(priority)
    }

    class DailyPlan {
        +owner: Owner
        +date: date
        +tasks: List[Task]
        +add_task(task)
        +sort_tasks()
        +generate_schedule()
        +explain_plan()
    }

    Owner "1" --> "0..*" Pet : manages
    Pet "1" --> "0..*" Task : includes
    DailyPlan "1" --> "0..*" Task : contains
    DailyPlan --> Owner : belongs to
